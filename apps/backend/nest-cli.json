{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "../@generated",
        "outDir": "dist/@generated"
      },
      {
        "include": "./**/*.graphql",
        "outDir": "dist/graphql/schema"
      }
    ],
    "watchAssets": true
  }
}
